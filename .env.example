PORT=4000
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
PLAYER_DATA_PATH=./data/players_accolades_bref.json
PLAYER_DATA_SOURCE=auto

# # Runtime/import connection. For Supabase, use the shared transaction-mode pooler.
# DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# # Migration and Prisma Studio connection. For Supabase, use the shared session-mode pooler.
# DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@[region].pooler.supabase.com:5432/postgres?sslmode=require"

DATABASE_URL="postgresql://postgres.sxupqlrgmuxxbgkzzfsx:YOUR_DATABASE_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

DIRECT_URL="postgresql://postgres.sxupqlrgmuxxbgkzzfsx:YOUR_DATABASE_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"


# Optional seeding controls.
SEED_MODE=bref
SEED_OFFSET=0
SEED_RESUME=false
SEED_SAVE_EVERY=5
SEED_GAME_WINS=false
SEED_REFRESH_GAME_WINS=false
NBA_STATS_DELAY_MS=1500
NBA_STATS_MAX_RETRIES=15
NBA_STATS_TIMEOUT_MS=30000
NBA_STATS_DIRECTORY_SEASON=2025-26
NBA_STATS_REFRESH_PLAYER_DIRECTORY=true
NBA_STATS_ID_MAP_PATH=./data/nba_stats_id_map.json
BREF_ADVANCED_DELAY_MS=4000
BREF_ADVANCED_RETRIES=3
BREF_ADVANCED_TIMEOUT_MS=30000
BREF_SEED_DELAY_MS=4000
BREF_SEED_RETRIES=3
BREF_SEED_TIMEOUT_MS=30000
BREF_SEED_SAVE_EVERY=10
