{
  "name": "nba_82-0_server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API and data seeding utilities for NBA 82-0.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node seed.js --mode=bref --replace --yes",
    "seed:bref": "node seed.js --mode=bref --replace --yes",
    "seed:bref:dry": "node seed.js --mode=bref --replace --yes --dryRun --skipFetch",
    "seed:bref:refresh": "node seed.js --mode=bref --replace --yes --refreshPerGame --refreshAdvanced",
    "seed:active": "node seed.js --mode=active",
    "seed:active:resume": "node seed.js --mode=active --resume",
    "seed:full": "node seed.js --mode=full",
    "seed:full:resume": "node seed.js --mode=full --resume",
    "seed:game-wins": "node seed.js --mode=active --gameWins --refreshGameWins",
    "seed:advanced-stats": "node seed-advanced-stats.js",
    "seed:stats": "node seed-stats.js --mode=active --maxCacheAgeDays=1 --force --appendMissingSeasons",
    "seed:games-started": "node seed-games-started.js",
    "seed:games_started": "npm run seed:games-started",
    "seed:bref-positions": "node seed-bref-positions.js",
    "seed:goat-rankings": "node seed-goat-rankings.js",
    "seed:legacy-points": "node seed-legacy-points.js",
    "seed:classic-points": "node eraRelativeClassicPoints.js",
    "backfill:season-stats": "node seed-stats.js",
    "refresh:league-averages": "node refresh-historical-league-averages.js",
    "refresh:positions": "python scripts/refresh_positions_nba_api.py",
    "refresh:positions:dry": "python scripts/refresh_positions_nba_api.py --dry-run",
    "fix:positions": "node fix-position-overrides.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1"
  }
}
